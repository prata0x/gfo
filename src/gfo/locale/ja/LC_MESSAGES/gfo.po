# commands/init.py
msgid "--type is required in non-interactive mode."
msgstr "非対話モードでは --type は必須です。"

msgid "Unknown service type '{service_type}'. Valid values: {valid}"
msgstr "不明なサービス種別 '{service_type}'。有効な値: {valid}"

msgid "--host is required in non-interactive mode."
msgstr "非対話モードでは --host は必須です。"

msgid "Could not detect repository from remote URL: {e} Please ensure you're in a git repository with an origin remote configured."
msgstr "リモート URL からリポジトリを検出できませんでした: {e} origin リモートが設定された git リポジトリ内にいることを確認してください。"

msgid "Initialized: {service_type} at {host}"
msgstr "初期化完了: {service_type} ({host})"

msgid "Detected: {service_type} at {host}"
msgstr "検出: {service_type} ({host})"

msgid "Is this correct? [Y/n]: "
msgstr "これで正しいですか？ [Y/n]: "

msgid "Could not auto-detect service. Please enter manually."
msgstr "サービスを自動検出できませんでした。手動で入力してください。"

msgid "Service type (github/gitlab/bitbucket/...): "
msgstr "サービス種別 (github/gitlab/bitbucket/...): "

msgid "Host: "
msgstr "ホスト: "

msgid "API URL (leave blank for default): "
msgstr "API URL (デフォルトの場合は空欄): "

msgid "Project key (leave blank if none): "
msgstr "プロジェクトキー (なければ空欄): "

msgid "Organization: "
msgstr "組織: "

msgid "Project key: "
msgstr "プロジェクトキー: "

msgid "Could not build API URL for {service_type}: {e}. Use --api-url to specify the URL manually."
msgstr "{service_type} の API URL を構築できませんでした: {e}。--api-url で手動指定してください。"

msgid "Could not build API URL automatically (organization or project key may be missing)."
msgstr "API URL を自動構築できませんでした（組織名またはプロジェクトキーが不足している可能性があります）。"

msgid "service_type cannot be empty."
msgstr "service_type は空にできません。"

msgid "Unknown service type {service_type}. Valid: {valid}"
msgstr "不明なサービス種別 {service_type}。有効: {valid}"

msgid "host cannot be empty."
msgstr "host は空にできません。"

# commands/auth_cmd.py
msgid "Could not detect host. Use --host option: gfo auth login --host <host>"
msgstr "ホストを検出できませんでした。--host オプションを使用してください: gfo auth login --host <host>"

msgid "Warning: passing tokens via --token is insecure."
msgstr "警告: --token でのトークン指定は安全ではありません。"

msgid "Token: "
msgstr "トークン: "

msgid "Token saved for {host}"
msgstr "{host} のトークンを保存しました"

msgid "No tokens configured."
msgstr "トークンが設定されていません。"

msgid "HOST"
msgstr "ホスト"

msgid "STATUS"
msgstr "ステータス"

msgid "SOURCE"
msgstr "ソース"

# commands/pr.py
msgid "Could not determine PR title. Use --title option."
msgstr "PR タイトルを決定できませんでした。--title オプションを使用してください。"

# commands/issue.py
msgid "--title must not be empty."
msgstr "--title は空にできません。"

msgid "--type must be a numeric issue type ID for Backlog, got {type}."
msgstr "Backlog の --type は数値の課題種別 ID が必要です。指定された値: {type}"

msgid "Deleted issue '{number}'."
msgstr "Issue '{number}' を削除しました。"

# commands/repo.py
msgid "Could not resolve host. Use --host option or set defaults.host in config.toml."
msgstr "ホストを解決できませんでした。--host オプションを使用するか config.toml で defaults.host を設定してください。"

msgid "Could not determine service type for host '{host}'. Configure it in config.toml: [hosts.{host}] type = \"...\""
msgstr "ホスト '{host}' のサービス種別を特定できませんでした。config.toml で設定してください: [hosts.{host}] type = \"...\""

msgid "Backlog requires a project key. Run 'gfo init' first to configure the project."
msgstr "Backlog にはプロジェクトキーが必要です。先に 'gfo init' を実行してプロジェクトを設定してください。"

msgid "Azure DevOps requires an organization and a project. Run 'gfo init' first to configure."
msgstr "Azure DevOps には組織とプロジェクトが必要です。先に 'gfo init' を実行して設定してください。"

msgid "Invalid repo format '{repo_arg}'. Expected 'owner/name' with non-empty owner and name."
msgstr "リポジトリの形式 '{repo_arg}' が不正です。'owner/name' の形式で owner と name を空にしないでください。"

msgid "Are you sure you want to delete repository '{repo_name}'? This action cannot be undone. [y/N]: "
msgstr "リポジトリ '{repo_name}' を削除してよろしいですか？この操作は取り消せません。 [y/N]: "

msgid "Aborted."
msgstr "中止しました。"

msgid "Deleted repository '{repo_name}'."
msgstr "リポジトリ '{repo_name}' を削除しました。"

# commands/release.py
msgid "tag must not be empty. Use 'gfo release create <tag>'."
msgstr "tag は空にできません。'gfo release create <tag>' を使用してください。"

msgid "tag must not be empty. Use 'gfo release delete <tag>'."
msgstr "tag は空にできません。'gfo release delete <tag>' を使用してください。"

msgid "Deleted release '{tag}'."
msgstr "リリース '{tag}' を削除しました。"

# commands/label.py
msgid "name must not be empty."
msgstr "name は空にできません。"

msgid "Invalid color '{color}'. Expected 6-digit hex color (e.g. ff0000)."
msgstr "色 '{color}' が不正です。6桁の16進数カラーコード (例: ff0000) を指定してください。"

msgid "Deleted label '{name}'."
msgstr "ラベル '{name}' を削除しました。"

