# gfo 統合テスト用環境変数テンプレート
# このファイルを .env にコピーして値を設定する
# .env は .gitignore に含まれるためコミットされない

# ===== SaaS サービス =====

# --- GitHub ---
GFO_TEST_GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GFO_TEST_GITHUB_OWNER=your-username
GFO_TEST_GITHUB_REPO=gfo-integration-test

# --- GitLab ---
GFO_TEST_GITLAB_TOKEN=glpat-xxxxxxxxxxxx
GFO_TEST_GITLAB_OWNER=your-username
GFO_TEST_GITLAB_REPO=gfo-integration-test

# --- Bitbucket ---
# スコープ付き API Token（email:api-token 形式）
# 必要スコープ: read:repository:bitbucket, read:pullrequest:bitbucket, write:pullrequest:bitbucket, read:issue:bitbucket, write:issue:bitbucket
GFO_TEST_BITBUCKET_TOKEN=your-email@example.com:ATATT-xxxxxxxxxxxx
GFO_TEST_BITBUCKET_OWNER=your-workspace
GFO_TEST_BITBUCKET_REPO=gfo-integration-test

# --- Azure DevOps ---
GFO_TEST_AZURE_DEVOPS_PAT=xxxxxxxxxxxx
GFO_TEST_AZURE_DEVOPS_ORG=your-organization
GFO_TEST_AZURE_DEVOPS_PROJECT=gfo-integration-test
GFO_TEST_AZURE_DEVOPS_REPO=gfo-integration-test
# OWNER は組織名と同じ値を設定する（ORG と同値で可）
GFO_TEST_AZURE_DEVOPS_OWNER=your-organization

# --- Backlog (有料サービス、アカウント保有者のみ) ---
# GFO_TEST_BACKLOG_API_KEY=xxxxxxxxxxxx
# GFO_TEST_BACKLOG_HOST=your-space.backlog.com
# GFO_TEST_BACKLOG_OWNER=your-project
# GFO_TEST_BACKLOG_REPO=gfo-integration-test
# GFO_TEST_BACKLOG_PROJECT_KEY=GFO

# ===== セルフホスト (setup_services.py が自動設定) =====
# 以下は setup_services.py 実行時に .env へ自動追記される
# 手動設定は不要

# GFO_TEST_GITEA_TOKEN=
# GFO_TEST_GITEA_HOST=localhost:3000
# GFO_TEST_GITEA_OWNER=gfo-admin
# GFO_TEST_GITEA_REPO=gfo-integration-test

# GFO_TEST_FORGEJO_TOKEN=
# GFO_TEST_FORGEJO_HOST=localhost:3001
# GFO_TEST_FORGEJO_OWNER=gfo-admin
# GFO_TEST_FORGEJO_REPO=gfo-integration-test

# GFO_TEST_GOGS_TOKEN=
# GFO_TEST_GOGS_HOST=localhost:3002
# GFO_TEST_GOGS_OWNER=gfo-admin
# GFO_TEST_GOGS_REPO=gfo-integration-test

# GFO_TEST_GITBUCKET_TOKEN=
# GFO_TEST_GITBUCKET_HOST=localhost:3003
# GFO_TEST_GITBUCKET_OWNER=root
# GFO_TEST_GITBUCKET_REPO=gfo-integration-test
